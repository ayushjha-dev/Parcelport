rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    
    // Helper function to check if user is authenticated
    function isAuthenticated() {
      return request.auth != null;
    }
    
    // Helper function to check if user owns the document
    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }
    
    // Users collection (for registration)
    match /users/{userId} {
      // Allow read if authenticated
      allow read: if isAuthenticated();
      
      // Allow create during registration (user creates their own document)
      allow create: if isAuthenticated() && request.auth.uid == userId;
      
      // Allow update if it's their own document
      allow update: if isAuthenticated() && request.auth.uid == userId;
      
      // Allow delete only by owner
      allow delete: if isAuthenticated() && request.auth.uid == userId;
    }
    
    // Students collection (for registration)
    match /students/{studentId} {
      // Allow read if authenticated
      allow read: if isAuthenticated();
      
      // Allow create during registration
      allow create: if isAuthenticated() && request.auth.uid == studentId;
      
      // Allow update if it's their own document
      allow update: if isAuthenticated() && request.auth.uid == studentId;
      
      // Allow delete only by owner
      allow delete: if isAuthenticated() && request.auth.uid == studentId;
    }
    
    // Profiles collection
    match /profiles/{profileId} {
      // Allow read if authenticated
      allow read: if isAuthenticated();
      
      // Allow create/update if authenticated and it's their own profile
      allow create: if isAuthenticated() && request.resource.data.id == request.auth.uid;
      allow update: if isAuthenticated() && resource.data.id == request.auth.uid;
      
      // Allow delete only by owner
      allow delete: if isAuthenticated() && resource.data.id == request.auth.uid;
    }
    
    // Parcels collection
    match /parcels/{parcelId} {
      // Allow read if authenticated
      allow read: if isAuthenticated();
      
      // Allow create if authenticated
      allow create: if isAuthenticated();
      
      // Allow update if authenticated (for status updates, etc.)
      allow update: if isAuthenticated();
      
      // Allow delete by owner or admin
      allow delete: if isAuthenticated();
    }
    
    // Delivery boys collection
    match /delivery_boys/{deliveryBoyId} {
      // Allow read if authenticated
      allow read: if isAuthenticated();
      
      // Allow write for admins (you can add admin check here)
      allow write: if isAuthenticated();
    }
    
    // Notifications collection
    match /notifications/{notificationId} {
      // Allow read if authenticated and it's their notification
      allow read: if isAuthenticated();
      
      // Allow create if authenticated
      allow create: if isAuthenticated();
      
      // Allow update/delete if it's their notification
      allow update, delete: if isAuthenticated();
    }
    
    // Payments collection
    match /payments/{paymentId} {
      // Allow read if authenticated
      allow read: if isAuthenticated();
      
      // Allow create if authenticated
      allow create: if isAuthenticated();
      
      // Allow update for payment status changes
      allow update: if isAuthenticated();
    }
    
    // Issues collection
    match /issues/{issueId} {
      // Allow read if authenticated
      allow read: if isAuthenticated();
      
      // Allow create if authenticated
      allow create: if isAuthenticated();
      
      // Allow update if authenticated
      allow update: if isAuthenticated();
    }
  }
}
